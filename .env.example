# Signal runs in TWO TIERS. With only the FREE keys it runs the full free tier;
# add the PREMIUM keys for better results (team / deep-social / pre_public signals).
# Any signal whose key is missing simply contributes 0 — nothing breaks.

# ===== TIER 1 — FREE  (no key, or a free key) =====
# GitHub: a free token only lifts rate limits — unlocks live velocity + code_health,
# and the FREE `team` signal (technical-CEO proxy, team size, frontier-lab alum).
GITHUB_TOKEN=
# On-chain signal: DefiLlama + Blockscout are public (no key). Switch chains here:
BLOCKSCOUT_BASE_URL=https://eth.blockscout.com
# Free HOSTED LLM scorer/memos — no GPU needed; pick ONE (all have a free tier). Any
# OpenAI-compatible provider works; the web UI "Scorer model" dropdown selects which.
GROQ_API_KEY=                                    # https://api.groq.com/openai/v1  (llama-3.3-70b-versatile)
GEMINI_API_KEY=                                  # https://generativelanguage.googleapis.com/v1beta/openai/  (gemini-2.0-flash)
OPENROUTER_API_KEY=                              # https://openrouter.ai/api/v1  (…llama-3.3-70b-instruct:free)
# CEREBRAS_API_KEY=                              # https://api.cerebras.ai/v1  (llama-3.3-70b)
# Free LOCAL LLM scorer/memos — used automatically when no hosted/frontier key is set.
OLLAMA_BASE_URL=http://localhost:11434/v1
LOCAL_MODEL=qwen2.5:14b
# (OpenRank Farcaster reputation, arXiv & IACR need no key.)

# ===== TIER 2 — PREMIUM  (paid / gated — better results) =====
# Frontier LLM scorer + memos (else falls back to local model, then heuristic).
ANTHROPIC_API_KEY=
FRONTIER_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
# team signal AUGMENT — adds prior exits / exit size / talent-flow on top of the free
# GitHub team signal (which works with just GITHUB_TOKEN above). Paid.
HARMONIC_API_KEY=
HARMONIC_SAVED_SEARCH_ID=
HARMONIC_PEOPLE_SEARCH_ID=
# social signal (deep) — Farcaster smart-followers + quality score (freemium -> paid).
NEYNAR_API_KEY=
FARCASTER_FUND_FID=
# pre_public signal — grants / hackathons / research detection (paid).
EVERTRACE_API_KEY=
# Messari — funding/stage gate (down-ranks already-funded, Series B/C+ cos) + tier-1 lead
# investor corroboration + attributed memo research context. Diligence/stage-gating, not discovery.
MESSARI_API_KEY=
# Nansen — UPGRADES onchain (Smart Money net inflow + smart-money holder share) AND adds on-chain
# smart-money convergence (the on-chain twin of network_radar). No key -> free DefiLlama/Blockscout
# onchain path runs unchanged. x402 pay-as-you-go option (~$0.01/query USDC on Base, no key):
NANSEN_API_KEY=
SIGNAL_NANSEN_X402=                              # set to 1 to use Nansen's x402 pay-per-query (no key)
# backtest: point-in-time Farcaster reconstruction (paid).
DUNE_API_KEY=
# optional web search.
EXA_API_KEY=

# ===== Output =====
SIGNAL_OUT_DIR=out
SIGNAL_DB=signal.db
